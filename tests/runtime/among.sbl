// Test among.

externals (stem)

routines (gate bgate)

stringescapes {}

define gate as 'q'

backwardmode (
  define bgate as 'q'
)

define stem as (
  test (
    among (
      'x' ()
      '' gate ()
    )
    ='gated default among case did not fail as expected'
  )
  test (
    backwards among (
      'a' bgate
      'bc' bgate
    )
    ='gated among did not fail as expected'
  )
)
